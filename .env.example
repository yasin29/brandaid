# Brand-AId Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env — it is gitignored.

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here

# Chat / multimodal model — adjust based on cost vs quality tradeoff.
# Higher capability: gpt-5.5, gpt-5.5-pro
# Balanced (recommended for dev/demo): gpt-5.4-mini
# Check platform.openai.com/docs/models for full list and pricing.
OPENAI_CHAT_MODEL=gpt-5.4-mini

# Embedding model for RAG
# text-embedding-3-small (cheaper) or text-embedding-3-large (more accurate)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- App ---
# URL of the frontend (used for CORS)
FRONTEND_URL=http://localhost:5173

# --- Web Search (DuckDuckGo MCP) ---
# No API key needed — duckduckgo-mcp-server is installed as a Python package.
# Audience research automatically uses it; falls back to OpenAI web_search_preview if it fails.

# --- ChromaDB ---
CHROMA_DB_PATH=data/chroma_db
CHROMA_COLLECTION_NAME=brand_aid_knowledge
