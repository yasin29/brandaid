# Brand-AId Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env — it is gitignored.

# --- Gemini (via OpenAI-compatible endpoint) ---
# Free API key from https://aistudio.google.com/apikey
# We keep the OPENAI_* variable names so the openai SDK plumbing stays unchanged.
OPENAI_API_KEY=your_gemini_api_key_here
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Chat / multimodal model.
# gemini-3.1-flash-lite: non-thinking, fast, vision-capable — best fit for our
# 300-800 max_completion_tokens caps (thinking models like gemini-3.5-flash burn
# the whole budget on reasoning and return empty responses).
OPENAI_CHAT_MODEL=gemini-3.1-flash-lite

# Embedding model for RAG (3072 dims — NOT compatible with an index built on
# OpenAI text-embedding-3-small; delete backend/data/chroma_db when switching).
OPENAI_EMBEDDING_MODEL=gemini-embedding-001

# --- App ---
# URL of the frontend (used for CORS)
FRONTEND_URL=http://localhost:5173

# --- Web Search (DuckDuckGo MCP) ---
# No API key needed — duckduckgo-mcp-server is installed as a Python package.
# Audience research uses it; on failure it degrades to static personas
# (the old OpenAI web_search_preview fallback is not supported on Gemini).

# --- ChromaDB ---
CHROMA_DB_PATH=data/chroma_db
CHROMA_COLLECTION_NAME=brand_aid_knowledge
